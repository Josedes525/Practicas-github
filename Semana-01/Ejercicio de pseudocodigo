Algoritmo CalcularPromedio
    
    Definir nota1, nota2, nota3, promedio Como Real
    
    // 2. Entrada de datos
    Escribir "Introduce la primera nota:"
    Leer nota1
    Escribir "Introduce la segunda nota:"
    Leer nota2
    Escribir "Introduce la tercera nota:"
    Leer nota3
    
  
    promedio <- (nota1 + nota2 + nota3) / 3
    

    Escribir "Tu promedio final es: ", promedio
    
    Si promedio >= 60 
        Escribir "Estado: Aprobado. ¡Felicidades!"
    Sino
        Escribir "Estado: Reprobado. Necesitas estudiar más."
    FinSi
    
FinAlgoritmo
